<PatchNewBin></PatchNewBin>
</RunParam>
<BatchParam>
<BatchMode>oar</BatchMode>
<RunTime>${MCRROOT712}</RunTime>
<CivBin>bin/civ</CivBin>
<Civ1Bin>bin/civ1</Civ1Bin>
<Civ2Bin>bin/civ2</Civ2Bin>

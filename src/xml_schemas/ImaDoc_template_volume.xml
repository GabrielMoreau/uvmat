      <Dtk unit="TimeUnit"> 10 </Dtk> <!-- time interval between two volume pairs , equivalent to <Dti>1 10</Dti> and <NbDti> 199 </NbDti> with no Dtk-->
      <NbDtk> 199 </NbDtk> <!-- nbre of volume pairs-->    
    </BurstTiming>
  </Camera>
